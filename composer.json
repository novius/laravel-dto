{
    "name": "novius/laravel-dto",
    "description": "A simple and extensible DTO package for Laravel",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "homepage": "https://github.com/novius/laravel-dto",
    "authors": [
        {
            "name": "Novius Agency",
            "email": "team-developpeurs@novius.com",
            "homepage": "https://www.novius.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "nunomaduro/larastan": "^2.0|^3.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0|^5.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0|^5.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0|^13.0"
    },
    "scripts": {
        "lint": "vendor/bin/pint",
        "test": "vendor/bin/pest",
        "analyze": "vendor/bin/phpstan analyse --memory-limit=512M"
    },
    "autoload": {
        "psr-4": {
            "Novius\\LaravelDto\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Novius\\LaravelDto\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Novius\\LaravelDto\\DtoServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
